// Export edit for tool buttons
window.editTool = function(id) {
    const t = AppDB.getTools().find(x => x.id === id);
    if (!t) return;
    document.getElementById('tool-form-id').value = t.id;
    document.getElementById('tool-name').value = t.name;
    document.getElementById('tool-serial').value = t.serial_number;
    document.getElementById('tool-category').value = t.category;
    if (document.getElementById('tool-status')) document.getElementById('tool-status').value = t.status;
    document.getElementById('tool-price').value = t.price || 0;
    
    window.currentToolImages = t.images ? [...t.images] : [];
    renderToolImagePreviews();
    
    document.getElementById('tool-modal-title').textContent = 'แก้ไขข้อมูลเครื่องมือช่าง';
    openModal('tool-form-modal');
};

// Global Array for Tool Images Upload
window.currentToolImages = [];

    
    Array.from(files).forEach(file => {
        const reader = new FileReader();
        reader.onload = function(e) {
            window.currentToolImages.push(e.target.result);
            renderToolImagePreviews();
        };
        reader.readAsDataURL(file);
    });
};

function renderToolImagePreviews() {
    const container = document.getElementById('tool-images-preview');
    if (!container) return;
    container.innerHTML = '';
    window.currentToolImages.forEach((imgSrc, idx) => {
        const div = document.createElement('div');
        div.style.position = 'relative';
        div.style.width = '80px';
        div.style.height = '80px';
        div.style.border = '1px solid #ddd';
        div.style.borderRadius = '4px';
        div.style.overflow = 'hidden';
        div.style.cursor = 'grab';
        div.draggable = true;
        div.dataset.index = idx;
        
        div.ondragstart = function(e) {
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', idx);
            setTimeout(() => this.style.opacity = '0.5', 0);
        };
        div.ondragend = function() {
            this.style.opacity = '1';
        };
        div.ondragover = function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            this.style.border = '2px dashed var(--accent)';
        };
        div.ondragleave = function() {
            this.style.border = '1px solid #ddd';
        };
        div.ondrop = function(e) {
            e.preventDefault();
            this.style.border = '1px solid #ddd';
            var dragIdx = parseInt(e.dataTransfer.getData('text/plain'), 10);
            var dropIdx = parseInt(this.dataset.index, 10);
            if (!isNaN(dragIdx) && !isNaN(dropIdx) && dragIdx !== dropIdx) {
                var draggedItem = window.currentToolImages[dragIdx];
                window.currentToolImages.splice(dragIdx, 1);
                window.currentToolImages.splice(dropIdx, 0, draggedItem);
                renderToolImagePreviews();
            }
        };
        
        const img = document.createElement('img');
        img.src = imgSrc;
        img.style.width = '100%';
        img.style.height = '100%';
        img.style.objectFit = 'cover';
        img.style.pointerEvents = 'none';
        
        const removeBtn = document.createElement('div');
        removeBtn.innerHTML = '&times;';
        removeBtn.style.position = 'absolute';
        removeBtn.style.top = '0';
        removeBtn.style.right = '0';
        removeBtn.style.background = 'rgba(255,0,0,0.7)';
        removeBtn.style.color = 'white';
        removeBtn.style.width = '20px';
        removeBtn.style.height = '20px';
        removeBtn.style.lineHeight = '20px';
        removeBtn.style.textAlign = 'center';
        removeBtn.style.cursor = 'pointer';
        removeBtn.style.zIndex = '10';
        removeBtn.onclick = function(evt) {
            evt.stopPropagation();
            window.currentToolImages.splice(idx, 1);
            renderToolImagePreviews();
        };
        
        div.appendChild(img);
        div.appendChild(removeBtn);
        container.appendChild(div);
    });
}

// Overwrite handleSaveTool
window.handleSaveTool = function(e) {
    e.preventDefault();
    const id = document.getElementById('tool-form-id').value;
    const tools = AppDB.getTools();
    
    let isNew = false;
    let t = tools.find(x => x.id === id);
    if(!t) {
        isNew = true;
        t = {
            id: 't' + Date.now(),
            current_project: 'à¸„à¸¥à¸±à¸‡à¸ªà¸´à¸™à¸„à¹‰à¸²à¸à¸¥à¸²à¸‡'
        };
        tools.push(t);
    }
    
    t.name = document.getElementById('tool-name').value;
    t.serial_number = document.getElementById('tool-serial').value;
    t.category = document.getElementById('tool-category').value;
    t.status = (document.getElementById('tool-status') && document.getElementById('tool-status').value) || (t.status || 'usable');
    t.price = parseFloat(document.getElementById('tool-price').value) || 0;
    
    // Save images from our global array
    t.images = window.currentToolImages.length > 0 ? [...window.currentToolImages] : (t.images || [AppDB.MOCK_IMAGES.tool]);
    
        // --- NEW APPROVAL LOGIC ---
    AppDB.addApproval({
        type: 'tool',
        action: isNew ? 'add' : 'edit',
        data: t,
        requested_by: (typeof currentUser !== 'undefined' && currentUser ? currentUser.name : 'Unknown')
    });
    
    AppDB.notifyTelegram('🔔 <b>มีรายการขออนุมัติใหม่</b>\nประเภท: <b>' + (isNew ? 'เพิ่มเครื่องมือใหม่' : 'แก้ไขข้อมูลเครื่องมือ') + '</b>\nรายการ: ' + t.name + '\nผู้ขอ: ' + (typeof currentUser !== 'undefined' && currentUser ? currentUser.name : 'Unknown'));

    if (typeof window.updateApprovalBadge === 'function') window.updateApprovalBadge();
    
    closeModal('tool-form-modal');
    
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            html: '<div style="font-size:24px; font-weight:bold; color:#10B981; margin-bottom:10px;"><i class="fas fa-check-circle"></i> บันทึกข้อมูลเครื่องมือสำเร็จ</div>' +
                  '<div style="font-size:18px;">' + t.name + '</div>' +
                  '<div style="color:#ef4444; font-weight:bold; margin-top:20px; padding:10px; background:#fee2e2; border-radius:8px; display:inline-block;">สถานะรออนุมัติ</div>',
            confirmButtonText: 'ตกลง',
            confirmButtonColor: '#3b82f6',
            width: '400px'
        });
    } else {
        showToast('บันทึกข้อมูลและส่งรออนุมัติสำเร็จ', 'success');
    }
    
    // Reset global array
    window.currentToolImages = [];
    renderToolImagePreviews();
    
    showToast(isNew ? 'à¹€à¸žà¸´à¹ˆà¸¡à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­à¹ƒà¸«à¸¡à¹ˆà¹à¸¥à¹‰à¸§' : 'à¸­à¸±à¸›à¹€à¸”à¸•à¸‚à¹‰à¸­à¸¡à¸¹à¸¥à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­à¹à¸¥à¹‰à¸§', 'success');
};

// View Details
window.viewToolDetails = function(id) {
