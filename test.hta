    document.getElementById('project-modal-title').textContent = 'à¹à¸à¹‰à¹„à¸‚à¹‚à¸„à¸£à¸‡à¸à¸²à¸£';
    openModal('project-modal');
}

function deleteProject(id) {
    if (confirm('à¸¢à¸·à¸™à¸¢à¸±à¸™à¸à¸²à¸£à¸¥à¸šà¹‚à¸„à¸£à¸‡à¸à¸²à¸£?')) {
        let prjs = AppDB.getProjects();
        prjs = prjs.filter(p => p.id !== id);
        saveToDB('Projects', prjs);
        renderProjects();
        showToast('à¸¥à¸šà¹‚à¸„à¸£à¸‡à¸à¸²à¸£à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', 'success');
    }
}

function handleProjectForm(e) {
    e.preventDefault();
    const id = document.getElementById('project-form-id').value;
    const prjs = AppDB.getProjects ? AppDB.getProjects() : [];
    
    const newPrj = {
        id: id || 'p' + Date.now(),
        name: document.getElementById('project-name').value,
        desc: document.getElementById('project-desc').value
    };
    
    if (id) {
        const idx = prjs.findIndex(p => p.id === id);
        if (idx !== -1) prjs[idx] = newPrj;
    } else {
        prjs.push(newPrj);
    }
    
    saveToDB('Projects', prjs);
    closeModal('project-modal');
    renderProjects();
    showToast('à¸šà¸±à¸™à¸—à¸¶à¸à¹‚à¸„à¸£à¸‡à¸à¸²à¸£à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', 'success');
}

// ========================
// WAREHOUSES CRUD
// ========================
function renderWarehouses() {
    const tbody = document.getElementById('warehouses-table-body');
    if (!tbody) return;
    tbody.innerHTML = '';
    const whs = AppDB.getWarehouses ? AppDB.getWarehouses() : [];
    whs.forEach(w => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td><strong>${w.name}</strong></td>
            <td><span class="status-badge status-usable">à¸›à¸à¸•à¸´</span></td>
            <td>
                <button class="btn btn-outline btn-sm" onclick="editWarehouse('${w.id}')"><i class="fas fa-edit"></i></button>
                <button class="btn btn-outline btn-sm" style="color:var(--danger);" onclick="deleteWarehouse('${w.id}')"><i class="fas fa-trash"></i></button>
            </td>
        `;
        tbody.appendChild(tr);
    });
}

function openAddWarehouseModal() {
