    const pf = document.getElementById('project-form-el');
    if (pf) pf.reset();
    document.getElementById('project-form-id').value = '';
    document.getElementById('project-modal-title').textContent = 'à¹€à¸žà¸´à¹ˆà¸¡à¹‚à¸„à¸£à¸‡à¸à¸²à¸£à¹ƒà¸«à¸¡à¹ˆ';
    openModal('project-modal');
}

