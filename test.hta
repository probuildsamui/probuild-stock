// ===  EXTENSION PATCH v2 - clean single append, no duplicates            ===
// =============================================================================

// ── 1. startVoice: silent (no toasts), permission warned only once ──────────
window.startVoice = function(inputId, btnId) {
    if (!('webkitSpeechRecognition' in window || 'SpeechRecognition' in window)) {
        if (!window._voiceNotSupportedWarned) {
            window._voiceNotSupportedWarned = true;
            showToast('เบราว์เซอร์ไม่รองรับระบบเสียง', 'error');
        }
        return;
    }
    var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    var recognition = new SR();
    recognition.lang = 'th-TH';
    recognition.interimResults = false;
    recognition.maxAlternatives = 1;
    var btn = document.getElementById(btnId);
    var origBg = btn ? btn.style.background : '';
    var origColor = btn ? btn.style.color : '';
    if (btn) { btn.style.background = '#ef4444'; btn.style.color = '#fff'; }

    recognition.onresult = function(event) {
        var text = event.results[0][0].transcript;
        var input = document.getElementById(inputId);
        if (input) { input.value = text; input.dispatchEvent(new Event('input')); }
        if (btn) { btn.style.background = origBg; btn.style.color = origColor; }
        if (inputId === 'withdraw-mat-name') updateWithdrawStockInfo(
            document.getElementById('withdraw-mat-location') ? document.getElementById('withdraw-mat-location').value : 'Stock A');
    };
    recognition.onerror = function(event) {
        if (btn) { btn.style.background = origBg; btn.style.color = origColor; }
        if (event.error === 'not-allowed' && !window._voicePermissionWarned) {
            window._voicePermissionWarned = true;
            showToast('กรุณาอนุญาตการใช้ไมโครโฟน (ครั้งเดียว)', 'error');
        }
    };
    recognition.onend = function() {
        if (btn) { btn.style.background = origBg; btn.style.color = origColor; }
    };
    recognition.start();
};

// ── 2. requestMicPermission: call once after login ──────────────────────────
window.requestMicPermission = function() {
    if (window._micPermissionRequested) return;
    window._micPermissionRequested = true;
    if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
        navigator.mediaDevices.getUserMedia({ audio: true })
            .then(function(stream) {
                stream.getTracks().forEach(function(t){ t.stop(); });
                window._voicePermissionGranted = true;
                window._voicePermissionWarned = true;
            }).catch(function(){});
    }
};

// ── 3. openAddMaterialModal: open material-add-modal ───────────────────────
window.openAddMaterialModal = function() {
    var fm = document.getElementById('add-mat-form');
    if (fm) fm.reset();
    var stocksContainer = document.getElementById('add-mat-stocks-container');
    if (stocksContainer) {
        var whs = AppDB.getWarehouses ? AppDB.getWarehouses() : [{code:'Stock A',name:'Stock A'},{code:'Stock B',name:'Stock B'},{code:'Stock C',name:'Stock C'}];
        stocksContainer.innerHTML = '';
        whs.forEach(function(w) {
            var fieldId = 'addmat-wh-' + w.id;
            stocksContainer.innerHTML += '<div class="form-group"><label class="form-label">' + w.name + '</label><input type="number" id="' + fieldId + '" data-whcode="' + w.code + '" class="form-control" min="0" value="0"></div>';
        });
    }
    openModal('material-add-modal');
};

// ── 4. handleAddMaterialForm: save new material ─────────────────────────────
window.handleAddMaterialForm = function(e) {
    e.preventDefault();
    var name = (document.getElementById('add-mat-name') && document.getElementById('add-mat-name').value || '').trim();
    if (!name) { showToast('กรุณาระบุชื่อวัสดุ', 'error'); return; }
    var category = (document.getElementById('add-mat-category') && document.getElementById('add-mat-category').value) || '';
    var unit = (document.getElementById('add-mat-unit') && document.getElementById('add-mat-unit').value || 'ชิ้น').trim();
    var price = parseFloat(document.getElementById('add-mat-price') && document.getElementById('add-mat-price').value) || 0;
    var minStock = parseInt(document.getElementById('add-mat-min') && document.getElementById('add-mat-min').value) || 0;

    var codeMap = {'Stock A':'stock_a_qty','Stock B':'stock_b_qty','Stock C':'stock_c_qty','Stock D':'stock_d_qty','Stock E':'stock_e_qty','Stock F':'stock_f_qty'};
    var stockData = {stock_a_qty:0, stock_b_qty:0, stock_c_qty:0};

    var inputs = document.querySelectorAll('#add-mat-stocks-container input[data-whcode]');
    inputs.forEach(function(inp) {
        var code = inp.getAttribute('data-whcode');
        var field = codeMap[code] || 'stock_a_qty';
        stockData[field] = (stockData[field] || 0) + (parseInt(inp.value) || 0);
    });

    var newMat = {
        id: 'm' + Date.now(), name: name, code: '', category: category, unit: unit,
        min_stock: minStock, price_per_unit: price,
        stock_a_qty: stockData.stock_a_qty, stock_b_qty: stockData.stock_b_qty, stock_c_qty: stockData.stock_c_qty,
        images: [(AppDB.MOCK_IMAGES && AppDB.MOCK_IMAGES.material) ? AppDB.MOCK_IMAGES.material : '']
    };
    Object.keys(stockData).forEach(function(k) { if (!newMat.hasOwnProperty(k)) newMat[k] = stockData[k]; });

    var mats = AppDB.getMaterials();
    mats.push(newMat);
    saveToDB('Materials', mats);
    closeModal('material-add-modal');
    renderMaterials();
    showToast('เพิ่มวัสดุ "' + name + '" เรียบร้อย', 'success');
    e.target.reset();
};

// ── 5. editMaterial: open edit modal with image preview ─────────────────────
window.editMaterial = function(id) {
    try {
        var mats = AppDB.getMaterials();
        var m = mats.find(function(x){ return x.id === id; });
        if (!m) { showToast('ไม่พบวัสดุ ID: ' + id, 'error'); return; }

        function setVal(elId, val) {
            var el = document.getElementById(elId);
            if (el) el.value = (val !== null && val !== undefined) ? val : '';
        }
        setVal('mat-form-id', m.id);
        setVal('mat-name', m.name || '');
        setVal('mat-code', m.code || '');
        setVal('mat-unit', m.unit || '');
        setVal('mat-min-stock', m.min_stock || 0);
        setVal('mat-price', m.price_per_unit || 0);
        setVal('mat-image-url', '');

        var catEl = document.getElementById('mat-category');
        if (catEl && m.category) {
            var found = false;
            for (var i = 0; i < catEl.options.length; i++) {
                if (catEl.options[i].value === m.category) { catEl.selectedIndex = i; found = true; break; }
            }
            if (!found) {
                var opt = document.createElement('option');
                opt.value = m.category; opt.text = m.category;
                catEl.appendChild(opt); catEl.value = m.category;
            }
        }

        window._matEditImages = (m.images && Array.isArray(m.images)) ? m.images.filter(Boolean).slice() : [];
        if (typeof renderMatEditImagePreview === 'function') renderMatEditImagePreview();

        var titleEl = document.getElementById('material-modal-title');
        if (titleEl) titleEl.textContent = 'แก้ไขวัสดุ: ' + m.name;
        openModal('material-edit-modal');
    } catch(err) {
        console.error('editMaterial error:', err);
        showToast('ข้อผิดพลาด: ' + err.message, 'error');
    }
};

// ── 6. renderMatEditImagePreview ─────────────────────────────────────────────
window._matEditImages = [];
window.renderMatEditImagePreview = function() {
    var preview = document.getElementById('mat-edit-image-preview');
    if (!preview) return;
    preview.innerHTML = '';
    (window._matEditImages || []).forEach(function(src, idx) {
        var wrap = document.createElement('div');
        wrap.style.cssText = 'position:relative; display:inline-block; cursor:grab;';
        wrap.draggable = true;
        wrap.dataset.index = idx;
        
        wrap.ondragstart = function(e) {
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', idx);
            setTimeout(() => this.style.opacity = '0.5', 0);
        };
        wrap.ondragend = function() {
            this.style.opacity = '1';
        };
        wrap.ondragover = function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            this.style.border = '2px dashed var(--accent)';
        };
        wrap.ondragleave = function() {
            this.style.border = 'none';
        };
        wrap.ondrop = function(e) {
            e.preventDefault();
            this.style.border = 'none';
            var dragIdx = parseInt(e.dataTransfer.getData('text/plain'), 10);
            var dropIdx = parseInt(this.dataset.index, 10);
            if (!isNaN(dragIdx) && !isNaN(dropIdx) && dragIdx !== dropIdx) {
                var draggedItem = window._matEditImages[dragIdx];
                window._matEditImages.splice(dragIdx, 1);
                window._matEditImages.splice(dropIdx, 0, draggedItem);
                window.renderMatEditImagePreview();
            }
        };

        var img = document.createElement('img');
        img.src = src;
        img.style.cssText = 'width:80px; height:80px; object-fit:cover; border-radius:8px; border:2px solid var(--border-color); pointer-events:none;';
        
        var del = document.createElement('button');
        del.type = 'button'; del.innerHTML = '&times;';
        del.style.cssText = 'position:absolute;top:-6px;right:-6px;background:#ef4444;color:#fff;border:none;border-radius:50%;width:20px;height:20px;cursor:pointer;font-size:14px;line-height:1;padding:0;z-index:10;';
        del.onclick = (function(i){ return function(evt){ evt.stopPropagation(); window._matEditImages.splice(i,1); window.renderMatEditImagePreview(); }; })(idx);
        
        wrap.appendChild(img); wrap.appendChild(del);
        preview.appendChild(wrap);
    });
};

// ── 7. handleMatImageUpload ──────────────────────────────────────────────────
window.handleMatImageUpload = function(input) {
    Array.from(input.files).forEach(function(file) {
        var reader = new FileReader();
        reader.onload = function(evt) {
            var img2 = new Image();
            img2.onload = function() {
                var canvas = document.createElement('canvas');
                var w = img2.width, h = img2.height, MAX = 800;
                if (w > h && w > MAX) { h = h*MAX/w; w = MAX; } else if (h > MAX) { w = w*MAX/h; h = MAX; }
                canvas.width = w; canvas.height = h;
                canvas.getContext('2d').drawImage(img2, 0, 0, w, h);
                window._matEditImages.push(canvas.toDataURL('image/jpeg', 0.7));
                window.renderMatEditImagePreview();
            };
            img2.src = evt.target.result;
        };
        reader.readAsDataURL(file);
    });
    input.value = '';
};

// ── 8. handleSaveMaterial: save edit with images ─────────────────────────────
window.handleSaveMaterial = function(e) {
    e.preventDefault();
    try {
        var id = (document.getElementById('mat-form-id') && document.getElementById('mat-form-id').value) || '';
        var mats = AppDB.getMaterials();
        var urlField = document.getElementById('mat-image-url');
        var images = (window._matEditImages && window._matEditImages.length > 0)
            ? window._matEditImages.slice()
            : (urlField && urlField.value ? [urlField.value] : [(AppDB.MOCK_IMAGES && AppDB.MOCK_IMAGES.material) ? AppDB.MOCK_IMAGES.material : '']);

        var newMat = {
            id: id || 'm' + Date.now(),
            name: (document.getElementById('mat-name') && document.getElementById('mat-name').value) || '',
            code: (document.getElementById('mat-code') && document.getElementById('mat-code').value) || '',
            category: (document.getElementById('mat-category') && document.getElementById('mat-category').value) || '',
            unit: (document.getElementById('mat-unit') && document.getElementById('mat-unit').value) || '',
            min_stock: parseInt(document.getElementById('mat-min-stock') && document.getElementById('mat-min-stock').value) || 0,
            price_per_unit: parseFloat(document.getElementById('mat-price') && document.getElementById('mat-price').value) || 0,
            stock_a_qty: 0, stock_b_qty: 0, stock_c_qty: 0,
            images: images
        };
        if (!newMat.name) { showToast('กรุณาระบุชื่อวัสดุ', 'error'); return; }

        if (id) {
            var idx = mats.findIndex(function(x){ return x.id === id; });
            if (idx !== -1) {
                newMat.stock_a_qty = mats[idx].stock_a_qty || 0;
                newMat.stock_b_qty = mats[idx].stock_b_qty || 0;
                newMat.stock_c_qty = mats[idx].stock_c_qty || 0;
                newMat.stock_d_qty = mats[idx].stock_d_qty || 0;
                newMat.stock_e_qty = mats[idx].stock_e_qty || 0;
                newMat.stock_f_qty = mats[idx].stock_f_qty || 0;
                newMat.stock_g_qty = mats[idx].stock_g_qty || 0;
                newMat.stock_h_qty = mats[idx].stock_h_qty || 0;
                newMat.stock_i_qty = mats[idx].stock_i_qty || 0;
                newMat.stock_j_qty = mats[idx].stock_j_qty || 0;
            }
        }

        AppDB.addApproval({
            type: 'material',
            action: id ? 'edit' : 'add',
            data: newMat,
            requested_by: (typeof currentUser !== 'undefined' && currentUser ? currentUser.name : 'Unknown')
        });
        
        AppDB.notifyTelegram('🔔 <b>มีรายการขออนุมัติใหม่</b>\nประเภท: <b>' + (id ? 'แก้ไขวัสดุ' : 'เพิ่มวัสดุใหม่') + '</b>\nรายการ: ' + newMat.name + '\nผู้ขอ: ' + (typeof currentUser !== 'undefined' && currentUser ? currentUser.name : 'Unknown'));

        if (typeof window.updateApprovalBadge === 'function') window.updateApprovalBadge();
        
        closeModal('material-edit-modal');
        
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                html: '<div style="font-size:24px; font-weight:bold; color:#10B981; margin-bottom:10px;"><i class="fas fa-check-circle"></i> บันทึกข้อมูลวัสดุสำเร็จ</div>' +
                      '<div style="font-size:18px;">' + newMat.name + '</div>' +
                      '<div style="color:#ef4444; font-weight:bold; margin-top:20px; padding:10px; background:#fee2e2; border-radius:8px; display:inline-block;">สถานะรออนุมัติ</div>',
                confirmButtonText: 'ตกลง',
                confirmButtonColor: '#3b82f6',
                width: '400px'
            });
        } else {
            showToast('บันทึกข้อมูลและส่งรออนุมัติสำเร็จ', 'success');
        }
        
        window._matEditImages = [];
    } catch(err) {
        console.error('handleSaveMaterial error:', err);
        showToast('ข้อผิดพลาด: ' + err.message, 'error');
    }
};

// ── 9. handleReceiveMaterialFixed ───────────────────────────────────────────
window.handleReceiveMaterialFixed = function(e) {
    e.preventDefault();
    try {
        var matName = (document.getElementById('receive-mat-name') && document.getElementById('receive-mat-name').value || '').trim();
        var qty = parseInt(document.getElementById('receive-mat-qty') && document.getElementById('receive-mat-qty').value) || 0;
        var location = (document.getElementById('receive-mat-location') && document.getElementById('receive-mat-location').value) || 'Stock A';
        if (!matName || qty <= 0) { showToast('กรุณาระบุชื่อวัสดุและจำนวน', 'error'); return; }
        var mats = AppDB.getMaterials();
        var m = mats.find(function(x){ return x.name === matName; }) ||
                mats.find(function(x){ return x.name && x.name.toLowerCase().indexOf(matName.toLowerCase()) >= 0; });
        if (!m) { showToast('ไม่พบวัสดุ "' + matName + '"', 'error'); return; }
        var codeMap = {'Stock A':'stock_a_qty','Stock B':'stock_b_qty','Stock C':'stock_c_qty','Stock D':'stock_d_qty'};
        var field = codeMap[location] || 'stock_a_qty';
        m[field] = (m[field] || 0) + qty;
        saveToDB('Materials', mats);
        if (typeof logMaterialAction === 'function') logMaterialAction(m.name, 'receive', qty, location, currentUser && currentUser.name);
        closeModal('receive-material-modal');
        renderMaterials();
        showToast('รับเข้า ' + m.name + ' ' + qty + ' ' + (m.unit||'ชิ้น') + ' สำเร็จ', 'success');
        e.target.reset();
    } catch(err) { console.error(err); showToast('ข้อผิดพลาด: ' + err.message, 'error'); }
};

// ── 10. handleWithdrawMaterialFinal ─────────────────────────────────────────
window.handleWithdrawMaterialFinal = function(e) {
    e.preventDefault();
    try {
        var matName = (document.getElementById('withdraw-mat-name') && document.getElementById('withdraw-mat-name').value || '').trim();
        var qty = parseInt(document.getElementById('withdraw-mat-qty') && document.getElementById('withdraw-mat-qty').value) || 0;
        var locationSel = document.getElementById('withdraw-mat-location');
        var location = locationSel ? locationSel.value : 'Stock A';
        var borrower = (document.getElementById('withdraw-mat-borrower') && document.getElementById('withdraw-mat-borrower').value) || '';
        if (!matName) { showToast('กรุณาระบุชื่อวัสดุ', 'error'); return; }
        if (qty <= 0) { showToast('กรุณาระบุจำนวนที่เบิก', 'error'); return; }
        if (!borrower) { showToast('กรุณาเลือกชื่อผู้เบิก', 'error'); return; }
        var mats = AppDB.getMaterials();
        var m = mats.find(function(x){ return x.name === matName; }) ||
                mats.find(function(x){ return x.name && x.name.toLowerCase().indexOf(matName.toLowerCase()) >= 0; });
        if (!m) { showToast('ไม่พบวัสดุ "' + matName + '"', 'error'); return; }
        var whs = AppDB.getWarehouses ? AppDB.getWarehouses() : [];
        var wh = whs.find(function(w){ return w.code === location || w.name === location; });
        var whCode = wh ? wh.code : location;
        var codeMap = {'Stock A':'stock_a_qty','Stock B':'stock_b_qty','Stock C':'stock_c_qty','Stock D':'stock_d_qty'};
        var field = codeMap[whCode] || 'stock_a_qty';
        var available = m[field] || 0;
        if (available < qty) { showToast('สต็อกใน ' + location + ' ไม่เพียงพอ (มี ' + available + ' ' + (m.unit||'ชิ้น') + ')', 'error'); return; }
        m[field] = available - qty;
        saveToDB('Materials', mats);
        if (typeof logMaterialAction === 'function') {
            var proj = (document.getElementById('withdraw-mat-project') && document.getElementById('withdraw-mat-project').value) || location;
            logMaterialAction(m.name, 'withdraw', qty, proj, borrower);
        }
        closeModal('withdraw-material-modal');
        renderMaterials();
        showToast('เบิก ' + m.name + ' ' + qty + ' ' + (m.unit||'ชิ้น') + ' สำเร็จ', 'success');
        e.target.reset();
        if (locationSel) { ['Stock A','Stock B','Stock C'].forEach(function(n,i){ if(locationSel.options[i]) locationSel.options[i].text = n; }); }
        var inf = document.getElementById('withdraw-stock-info');
        if (inf) inf.textContent = '';
    } catch(err) { console.error(err); showToast('ข้อผิดพลาด: ' + err.message, 'error'); }
};

// ── 11. openReceiveMaterialModal: auto-fill + pre-fill name ─────────────────
window.openReceiveMaterialModal = function(matId) {
    var nameInput = document.getElementById('receive-mat-name');
    if (nameInput) {
        if (matId) {
            var m = AppDB.getMaterials().find(function(x){ return x.id === matId; });
            if (m) nameInput.value = m.name; else nameInput.value = '';
        } else nameInput.value = '';
    }
    var authInput = document.getElementById('receive-mat-auth');
    if (authInput && typeof currentUser !== 'undefined' && currentUser) authInput.value = currentUser.name || '';
    openModal('receive-material-modal');
};

// ── 12. openWithdrawMaterialModal: populate dropdowns ───────────────────────
window.openWithdrawMaterialModal = function(matId) {
    window._withdrawCurrentMat = null;
    var nameInput = document.getElementById('withdraw-mat-name');
    if (nameInput) {
        if (matId) {
            var m = AppDB.getMaterials().find(function(x){ return x.id === matId; });
            if (m) { nameInput.value = m.name; window._withdrawCurrentMat = m; }
            else nameInput.value = '';
        } else nameInput.value = '';
    }
    var borrowerSel = document.getElementById('withdraw-mat-borrower');
    if (borrowerSel) {
        borrowerSel.innerHTML = '<option value="" disabled selected>-- เลือกชื่อพนักงาน --</option>';
        var users = AppDB.getUsers ? AppDB.getUsers() : [];
        users.forEach(function(u) { borrowerSel.innerHTML += '<option value="' + u.name + '">' + u.name + '</option>'; });
    }
    var authInput = document.getElementById('withdraw-mat-auth');
    if (authInput && typeof currentUser !== 'undefined' && currentUser) authInput.value = currentUser.name || '';
    updateWithdrawStockInfo((document.getElementById('withdraw-mat-location') && document.getElementById('withdraw-mat-location').value) || 'Stock A');
    openModal('withdraw-material-modal');
};

// ── 13. updateWithdrawStockInfo ──────────────────────────────────────────────
window.updateWithdrawStockInfo = function(location) {
    var infoDiv = document.getElementById('withdraw-stock-info');
    var locationSel = document.getElementById('withdraw-mat-location');
    if (!infoDiv) return;
    var nameInput = document.getElementById('withdraw-mat-name');
    var matName = nameInput && nameInput.value.trim();
    var mat = window._withdrawCurrentMat;
    if (!mat && matName) mat = AppDB.getMaterials().find(function(x){ return x.name && x.name.toLowerCase().indexOf(matName.toLowerCase()) >= 0; });
    if (mat && locationSel) {
        var whs = AppDB.getWarehouses ? AppDB.getWarehouses() : [{code:'Stock A',name:'Stock A'},{code:'Stock B',name:'Stock B'},{code:'Stock C',name:'Stock C'}];
        var codeMap = {'Stock A':'stock_a_qty','Stock B':'stock_b_qty','Stock C':'stock_c_qty'};
        whs.forEach(function(w, i) {
            if (locationSel.options[i]) locationSel.options[i].text = w.name + ' (' + (mat[codeMap[w.code]||'stock_a_qty'] || 0) + ' ' + (mat.unit||'') + ')';
        });
        var field = codeMap[location] || 'stock_a_qty';
        var qty = mat[field] || 0;
        infoDiv.textContent = 'คงเหลือใน ' + location + ': ' + qty + ' ' + (mat.unit||'ชิ้น');
        infoDiv.style.color = qty > 0 ? 'var(--accent)' : '#ef4444';
    } else {
        infoDiv.textContent = '';
        if (locationSel) { ['Stock A','Stock B','Stock C'].forEach(function(n,i){ if(locationSel.options[i]) locationSel.options[i].text = n; }); }
    }
};

// ── 14. handleSaveMaterial alias ────────────────────────────────────────────
window.handleSaveMaterial = window.handleSaveMaterial; // already defined above



// --- NEW APPROVALS VIEW LOGIC ---
window.renderApprovals = function() {
    const container = document.getElementById('view-approvals');
    if (!container) return;
    
    const approvals = AppDB.getApprovals();
    
    let html = '<div class="card" style="margin-bottom: 24px;">';
    html += '<div class="list-widget-header" style="margin-bottom:20px;">';
    html += '<h3 class="list-widget-title" style="color: var(--accent);"><i class="fas fa-clipboard-check"></i> รายการรออนุมัติ (' + approvals.length + ')</h3>';
    html += '</div>';
    
    if (approvals.length === 0) {
        html += '<div style="text-align:center; padding:40px; color:#6b7280;">ไม่มีรายการรออนุมัติในขณะนี้</div>';
    } else {
        html += '<div class="table-wrapper"><table class="app-table"><thead><tr>';
        html += '<th>วันที่/เวลา</th><th>ประเภท</th><th>รายการ</th><th>ผู้ขอ</th><th>สถานะ</th><th>จัดการ</th>';
        html += '</tr></thead><tbody>';
        
        approvals.forEach(req => {
            const dateStr = new Date(req.timestamp).toLocaleString('th-TH');
            let typeLabel = '';
            if (req.type === 'material') {
                typeLabel = req.action === 'add' ? '<span class="badge" style="background:#3b82f6;color:white;">เพิ่มวัสดุ</span>' : '<span class="badge" style="background:#f59e0b;color:white;">แก้ไขวัสดุ</span>';
            } else if (req.type === 'tool') {
                typeLabel = req.action === 'add' ? '<span class="badge" style="background:#10b981;color:white;">เพิ่มเครื่องมือ</span>' : '<span class="badge" style="background:#ef4444;color:white;">ยุติการใช้งานเครื่องมือ</span>';
            }
            
            const itemName = req.data ? req.data.name : '-';
            
            html += '<tr>';
            html += '<td>' + dateStr + '</td>';
            html += '<td>' + typeLabel + '</td>';
            html += '<td><strong>' + itemName + '</strong></td>';
            html += '<td>' + (req.requested_by || '-') + '</td>';
            html += '<td><span class="badge" style="background:#ef4444;color:white;">รออนุมัติ</span></td>';
            html += '<td>';
            html += '<button class="btn btn-sm btn-success" onclick="approveItem(\'' + req.id + '\')" style="margin-right:5px;"><i class="fas fa-check"></i> อนุมัติ</button>';
            html += '<button class="btn btn-sm btn-danger" onclick="rejectItem(\'' + req.id + '\')"><i class="fas fa-times"></i> ไม่อนุมัติ</button>';
            html += '</td>';
            html += '</tr>';
        });
        
        html += '</tbody></table></div>';
    }
    
    html += '</div>';
    container.innerHTML = html;
};

window.approveItem = function(id) {
    if (confirm('คุณต้องการอนุมัติรายการนี้ใช่หรือไม่?')) {
        try {
            AppDB.approveRequest(id, currentUser.name);
            showToast('อนุมัติรายการสำเร็จ', 'success');
            renderApprovals();
            if (typeof window.updateApprovalBadge === 'function') window.updateApprovalBadge();
        } catch(e) {
            showToast(e.message, 'error');
        }
    }
};

window.rejectItem = function(id) {
    if (confirm('คุณต้องการไม่อนุมัติและลบคำขอนี้ทิ้งใช่หรือไม่?')) {
        try {
            AppDB.rejectRequest(id, currentUser.name);
            showToast('ปฏิเสธรายการสำเร็จ', 'success');
            renderApprovals();
            if (typeof window.updateApprovalBadge === 'function') window.updateApprovalBadge();
        } catch(e) {
            showToast(e.message, 'error');
        }
    }
};




// SUCCESS POPUP (centered modal, replaces corner toast)
window.showSuccessPopup = function(msg) {
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            html: '<div style="font-size:24px; font-weight:bold; color:#10B981; margin-bottom:10px;"><i class="fas fa-check-circle"></i></div><div style="font-size:18px; white-space:pre-line;">' + msg + '</div>',
            confirmButtonText: 'ตกลง',
            confirmButtonColor: '#3b82f6',
            width: '400px'
        });
        return;
    }
    var old = document.getElementById('_sp_overlay');
    if (old) old.remove();
    var ov = document.createElement('div');
    ov.id = '_sp_overlay';
    ov.style.cssText = 'position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);';
    var card = document.createElement('div');
    card.style.cssText = 'background:#fff;border-radius:16px;padding:32px 40px;max-width:420px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.3);text-align:center;font-family:inherit;';
    var icon = document.createElement('div');
    icon.innerHTML = '<i class="fas fa-check-circle" style="font-size:48px;color:#10b981;margin-bottom:16px;"></i>';
    var txt = document.createElement('div');
    txt.style.cssText = 'font-size:16px;color:#1e293b;font-weight:600;line-height:1.7;margin-bottom:24px;white-space:pre-line;';
    txt.textContent = msg;
    var btn = document.createElement('button');
    btn.textContent = 'ตกลง';
    btn.style.cssText = 'background:#3b82f6;color:#fff;border:none;border-radius:10px;padding:12px 48px;font-size:16px;font-weight:700;cursor:pointer;';
    btn.onclick = function(){ ov.remove(); };
    ov.onclick = function(e){ if(e.target===ov) ov.remove(); };
    card.appendChild(icon);
    card.appendChild(txt);
    card.appendChild(btn);
    ov.appendChild(card);
    document.body.appendChild(ov);
    setTimeout(function(){ if(ov.parentNode) ov.remove(); }, 10000);
};

var _oToast = window.showToast;
window.showToast = function(msg, type) {
    type = type || 'info';
    if (type === 'success' || type === 'error') {
        window.showSuccessPopup(msg);
    } else {
        if (typeof _oToast === 'function') try { _oToast(msg, type); } catch(e){}
    }
};
</script>
