    document.getElementById('detail-tool-warranty').textContent = 'à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­à¸Šà¹ˆà¸²à¸‡à¹ƒà¸™à¸£à¸°à¸šà¸š';
    document.getElementById('detail-tool-store').textContent = t.current_project || 'à¹„à¸¡à¹ˆà¸£à¸°à¸šà¸¸';
    document.getElementById('detail-tool-purchased').textContent = t.current_borrower || 'à¹„à¸¡à¹ˆà¸¡à¸µà¸œà¸¹à¹‰à¸¢à¸·à¸¡';
    
    const gallery = document.getElementById('detail-tool-gallery');
    gallery.innerHTML = '';
