    if (wf) wf.reset();
    document.getElementById('warehouse-form-id').value = '';
    document.getElementById('warehouse-modal-title').textContent = 'à¹€à¸žà¸´à¹ˆà¸¡à¸„à¸¥à¸±à¸‡à¸¢à¹ˆà¸­à¸¢à¹ƒà¸«à¸¡à¹ˆ';
    openModal('warehouse-modal');
}

function editWarehouse(id) {
    const wh = AppDB.getWarehouses().find(w => w.id === id);
    if (!wh) return;
    document.getElementById('warehouse-form-id').value = wh.id;
    document.getElementById('warehouse-name').value = wh.name;
    document.getElementById('warehouse-modal-title').textContent = 'à¹à¸à¹‰à¹„à¸‚à¸„à¸¥à¸±à¸‡à¸¢à¹ˆà¸­à¸¢';
    openModal('warehouse-modal');
}

function deleteWarehouse(id) {
    if (confirm('à¸¢à¸·à¸™à¸¢à¸±à¸™à¸à¸²à¸£à¸¥à¸šà¸„à¸¥à¸±à¸‡à¸§à¸±à¸ªà¸”à¸¸?')) {
        let whs = AppDB.getWarehouses();
        whs = whs.filter(w => w.id !== id);
        saveToDB('Warehouses', whs);
        renderWarehouses();
        showToast('à¸¥à¸šà¸„à¸¥à¸±à¸‡à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', 'success');
    }
}

function handleWarehouseForm(e) {
    e.preventDefault();
    const id = document.getElementById('warehouse-form-id').value;
    const whs = AppDB.getWarehouses ? AppDB.getWarehouses() : [];
    
    const newWh = {
        id: id || 'w' + Date.now(),
        name: document.getElementById('warehouse-name').value
    };
    
    if (id) {
        const idx = whs.findIndex(w => w.id === id);
        if (idx !== -1) whs[idx] = newWh;
    } else {
        whs.push(newWh);
    }
    
    saveToDB('Warehouses', whs);
    closeModal('warehouse-modal');
    renderWarehouses();
    showToast('à¸šà¸±à¸™à¸—à¸¶à¸à¸„à¸¥à¸±à¸‡à¸§à¸±à¸ªà¸”à¸¸à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', 'success');
}

// ========================
// MATERIALS LOGIC
// ========================
function openAddMaterialModal() {
    document.getElementById('mat-form-id').value = '';
    const mf = document.getElementById('material-edit-form');
    if(mf) mf.reset();
    document.getElementById('material-modal-title').textContent = 'à¹€à¸žà¸´à¹ˆà¸¡à¸§à¸±à¸ªà¸”à¸¸à¸ªà¸´à¸™à¸„à¹‰à¸²à¹ƒà¸«à¸¡à¹ˆ';
    openModal('material-add-modal');
}

window.editMaterial = function(id) {
    const m = AppDB.getMaterials().find(x => x.id === id);
    if (!m) return;
    document.getElementById('mat-form-id').value = m.id;
    document.getElementById('mat-name').value = m.name;
    document.getElementById('mat-code').value = m.code || '';
    document.getElementById('mat-category').value = m.category;
    document.getElementById('mat-unit').value = m.unit;
    document.getElementById('mat-min-stock').value = m.min_stock;
    document.getElementById('mat-price').value = m.price_per_unit || 0;
    document.getElementById('mat-image-url').value = m.images?.[0] || '';
    document.getElementById('material-modal-title').textContent = 'à¹à¸à¹‰à¹„à¸‚à¸‚à¹‰à¸­à¸¡à¸¹à¸¥à¸§à¸±à¸ªà¸”à¸¸';
    openModal('material-add-modal');
};

function handleMaterialForm(e) {
    e.preventDefault();
    const id = document.getElementById('mat-form-id').value;
    const mats = AppDB.getMaterials();
    
    const newMat = {
        id: id || 'm' + Date.now(),
        name: document.getElementById('mat-name').value,
        code: document.getElementById('mat-code').value,
        category: document.getElementById('mat-category').value,
        unit: document.getElementById('mat-unit').value,
        min_stock: parseInt(document.getElementById('mat-min-stock').value) || 0,
        price_per_unit: parseFloat(document.getElementById('mat-price').value) || 0,
        stock_a_qty: 0,
        stock_b_qty: 0,
        stock_c_qty: 0,
        images: [document.getElementById('mat-image-url').value || AppDB.MOCK_IMAGES.material]
    };
    
    if (id) {
        const idx = mats.findIndex(m => m.id === id);
        if (idx !== -1) {
            newMat.stock_a_qty = mats[idx].stock_a_qty;
            newMat.stock_b_qty = mats[idx].stock_b_qty;
            newMat.stock_c_qty = mats[idx].stock_c_qty;
            mats[idx] = newMat;
        }
    } else {
        mats.push(newMat);
    }
    
    saveToDB('Materials', mats);
    closeModal('material-edit-modal');
    renderMaterials();
    showToast('à¸šà¸±à¸™à¸—à¸¶à¸à¸‚à¹‰à¸­à¸¡à¸¹à¸¥à¸§à¸±à¸ªà¸”à¸¸à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', 'success');
}

function handleReceiveMaterial(e) {
    e.preventDefault();
    const id = document.getElementById('receive-mat-id').value;
    const qty = parseInt(document.getElementById('receive-qty').value) || 0;
    const mats = AppDB.getMaterials();
    const m = mats.find(x => x.id === id);
    if(m) {
        m.stock_a_qty = (m.stock_a_qty || 0) + qty; // default to Stock A
        saveToDB('Materials', mats);
        logMaterialAction(m.name, 'receive', qty, 'à¸£à¸±à¸šà¹€à¸‚à¹‰à¸²à¸„à¸¥à¸±à¸‡à¸«à¸¥à¸±à¸', currentUser?.name);
        closeModal('receive-material-modal');
        renderMaterials();
        showToast(`à¸£à¸±à¸šà¹€à¸‚à¹‰à¸²à¸§à¸±à¸ªà¸”à¸¸ ${m.name} à¸ˆà¸³à¸™à¸§à¸™ ${qty} à¸ªà¸³à¹€à¸£à¹‡à¸ˆ`, 'success');
    }
}

function handleWithdrawMaterial(e) {
    e.preventDefault();
    const id = document.getElementById('withdraw-mat-id').value;
    const qty = parseInt(document.getElementById('withdraw-qty').value) || 0;
    const proj = document.getElementById('withdraw-project').value;
    const mats = AppDB.getMaterials();
    const m = mats.find(x => x.id === id);
    if(m) {
        if((m.stock_a_qty || 0) + (m.stock_b_qty || 0) + (m.stock_c_qty || 0) < qty) {
            showToast('à¸ªà¸•à¹‡à¸­à¸à¹„à¸¡à¹ˆà¹€à¸žà¸µà¸¢à¸‡à¸žà¸­', 'error');
            return;
        }
        // simplistic logic: deduct from Stock A
        m.stock_a_qty = Math.max(0, (m.stock_a_qty || 0) - qty);
        saveToDB('Materials', mats);
        logMaterialAction(m.name, 'withdraw', qty, proj, currentUser?.name);
        closeModal('withdraw-material-modal');
        renderMaterials();
        showToast(`à¹€à¸šà¸´à¸à¸§à¸±à¸ªà¸”à¸¸ ${m.name} à¸ˆà¸³à¸™à¸§à¸™ ${qty} à¸ªà¸³à¹€à¸£à¹‡à¸ˆ`, 'success');
    }
}

function logMaterialAction(name, action, qty, proj, user) {
    const logs = AppDB.getMaterialLogs() || [];
    logs.push({
        id: 'mlog' + Date.now(),
        timestamp: new Date().toISOString(),
        material_name: name,
        action: action,
        qty: qty,
        project: proj,
        borrower_name: user,
        approver_name: user
    });
    saveToDB('MaterialLogs', logs);
}

// ========================
// TOOLS LOGIC
// ========================
function handleToolForm(e) {
    e.preventDefault();
    const id = document.getElementById('tool-form-id').value;
    const tools = AppDB.getTools();
    
    const newTool = {
        id: id || 't' + Date.now(),
        name: document.getElementById('tool-name').value,
        serial_number: document.getElementById('tool-serial').value,
        category: document.getElementById('tool-category').value,
        status: (document.getElementById('tool-status') && document.getElementById('tool-status').value) || 'usable',
        current_project: 'à¸„à¸¥à¸±à¸‡à¸ªà¸´à¸™à¸„à¹‰à¸²à¸à¸¥à¸²à¸‡',
        price: parseFloat(document.getElementById('tool-price').value) || 0,
        warranty_expiry: document.getElementById('tool-warranty').value || null,
        images: [document.getElementById('tool-image-url').value || AppDB.MOCK_IMAGES.drill]
    };
    
    if (id) {
        const idx = tools.findIndex(t => t.id === id);
        if (idx !== -1) {
            newTool.current_project = tools[idx].current_project; // preserve project
            tools[idx] = newTool;
        }
    } else {
        tools.push(newTool);
    }
    
        // --- NEW APPROVAL LOGIC ---
    AppDB.addApproval({
        type: 'tool',
        action: isNew ? 'add' : 'edit',
        data: t,
        requested_by: (typeof currentUser !== 'undefined' && currentUser ? currentUser.name : 'Unknown')
    });
    
    AppDB.notifyTelegram('🔔 <b>มีรายการขออนุมัติใหม่</b>\nประเภท: <b>' + (isNew ? 'เพิ่มเครื่องมือใหม่' : 'แก้ไขข้อมูลเครื่องมือ') + '</b>\nรายการ: ' + t.name + '\nผู้ขอ: ' + (typeof currentUser !== 'undefined' && currentUser ? currentUser.name : 'Unknown'));

    if (typeof window.updateApprovalBadge === 'function') window.updateApprovalBadge();
    
    closeModal('tool-form-modal');
    
    if (typeof Swal !== 'undefined') {
        Swal.fire({
            html: '<div style="font-size:24px; font-weight:bold; color:#10B981; margin-bottom:10px;"><i class="fas fa-check-circle"></i> บันทึกข้อมูลเครื่องมือสำเร็จ</div>' +
                  '<div style="font-size:18px;">' + t.name + '</div>' +
                  '<div style="color:#ef4444; font-weight:bold; margin-top:20px; padding:10px; background:#fee2e2; border-radius:8px; display:inline-block;">สถานะรออนุมัติ</div>',
            confirmButtonText: 'ตกลง',
            confirmButtonColor: '#3b82f6',
            width: '400px'
        });
    } else {
        showToast('บันทึกข้อมูลและส่งรออนุมัติสำเร็จ', 'success');
    }
    showToast('à¸šà¸±à¸™à¸—à¸¶à¸à¸‚à¹‰à¸­à¸¡à¸¹à¸¥à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', 'success');
}

function handleBorrowTool(e) {
    e.preventDefault();
    const tools = AppDB.getTools();
    const id = document.getElementById('borrow-tool-id').value;
    const proj = document.getElementById('borrow-tool-project').value;
    const user = document.getElementById('borrow-tool-borrower').value;
    
    const t = tools.find(x => x.id === id);
    if(t) {
        t.current_project = proj;
        t.current_borrower = user;
        t.status = 'in-use';
        saveToolsArray(tools);
        logToolAction(t.name, 'borrow', proj, user);
        closeModal('borrow-tool-modal');
        renderTools();
        showCenterAlert('à¸¢à¸·à¸¡à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', `à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­ ${t.name} à¸–à¸¹à¸à¸¢à¸·à¸¡à¸ªà¸³à¹€à¸£à¹‡à¸ˆà¹‚à¸”à¸¢ ${user}`);
    }
}

function handleReturnTool(e) {
    e.preventDefault();
    const tools = AppDB.getTools();
    const id = document.getElementById('return-tool-id').value;
    const condition = document.getElementById('return-tool-condition').value;
    const returner = document.getElementById('return-tool-borrower').value;
    const location = document.getElementById('return-tool-location').value;
    const auth = document.getElementById('return-tool-auth').value;
    
    // Get signature data
    let signatureData = null;
    if (typeof sigCanvas !== 'undefined' && sigCanvas) {
        signatureData = sigCanvas.toDataURL('image/png');
    }
    
    const t = tools.find(x => x.id === id);
    if(t) {
        t.current_project = location;
        t.current_borrower = null;
        t.status = condition === 'damaged' ? 'damaged' : 'ready';
        saveToolsArray(tools);
        logToolAction(t.name, 'return', location, returner);
        // We could also log signatureData if needed, but for now we just process the return
        closeModal('return-tool-modal');
        renderTools();
        showCenterAlert('à¸„à¸·à¸™à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', `à¹€à¸„à¸£à¸·à¹ˆà¸­à¸‡à¸¡à¸·à¸­ ${t.name} à¸–à¸¹à¸à¸„à¸·à¸™à¸ªà¸³à¹€à¸£à¹‡à¸ˆà¹‚à¸”à¸¢ ${returner} à¸ˆà¸±à¸”à¹€à¸à¹‡à¸šà¸—à¸µà¹ˆ ${location}`);
    }
}

