    document.getElementById('tool-details-modal').dataset.toolId = id;
    openModal('tool-details-modal');
};

let currentEditImages = [];
window.openEditToolImagesModal = function() {
    const toolId = document.getElementById('tool-details-modal').dataset.toolId;
    if (!toolId) return;
    const tools = AppDB.getTools();
    const t = tools.find(x => x.id === toolId);
    if (!t) return;
    
    document.getElementById('edit-image-tool-id').value = toolId;
    currentEditImages = t.images && t.images.length > 0 ? [...t.images] : [AppDB.MOCK_IMAGES.tool];
    
    renderEditToolImages();
    openModal('tool-image-edit-modal');
};

function renderEditToolImages() {
    const preview = document.getElementById('edit-tool-images-preview');
    preview.innerHTML = '';
    currentEditImages.forEach((imgSrc, idx) => {
        const div = document.createElement('div');
        div.style.position = 'relative';
        div.style.width = '80px';
        div.style.height = '80px';
        div.innerHTML = `
            <img src="${imgSrc}" style="width:100%; height:100%; object-fit:cover; border-radius:6px; border:1px solid #e2e8f0;">
            <button type="button" onclick="removeEditToolImage(${idx})" style="position:absolute; top:-5px; right:-5px; background:var(--danger); color:white; border:none; border-radius:50%; width:20px; height:20px; font-size:10px; cursor:pointer; display:flex; align-items:center; justify-content:center;"><i class="fas fa-times"></i></button>
        `;
        preview.appendChild(div);
    });
}

window.removeEditToolImage = function(index) {
    currentEditImages.splice(index, 1);
    renderEditToolImages();
};

window.handleEditToolImageUpload = function(event) {
    const files = event.target.files;
    if (files && files.length > 0) {
        Array.from(files).forEach(file => {
            const reader = new FileReader();
            reader.onload = (e) => {
                currentEditImages.push(e.target.result);
                renderEditToolImages();
            };
            reader.readAsDataURL(file);
        });
    }
};

window.saveToolImages = function() {
