<script>// logic.js
// Handles all CRUD operations, Modals, and additional features

document.addEventListener('DOMContentLoaded', () => {
    bindForms();
    
    // Initialize render if not already done by app.js for new modules
    setTimeout(() => {
        if(currentView === 'users') renderUsers();
        if(currentView === 'projects') renderProjects();
        if(currentView === 'warehouses') renderWarehouses();
    }, 500);
});

function bindForms() {
    bindSearch();
    // Users
    const uf = document.getElementById('user-form-el');
    if (uf) uf.addEventListener('submit', handleUserForm);
    
    // Projects
    const pf = document.getElementById('project-form-el');
    if (pf) pf.addEventListener('submit', handleProjectForm);
    
    // Warehouses
    const wf = document.getElementById('warehouse-form-el');
    if (wf) wf.addEventListener('submit', handleWarehouseForm);

    // Materials - Add/Edit
    const mf = document.getElementById('material-edit-form');
    if (mf) mf.addEventListener('submit', handleMaterialForm);

    // Tools - Add/Edit
    const tf = document.getElementById('tool-form');
    if (tf) tf.addEventListener('submit', handleToolForm);

    // Stock Operations
    const rmf = document.getElementById('receive-mat-form');
    if (rmf) rmf.addEventListener('submit', handleReceiveMaterial);
    
    const wmf = document.getElementById('withdraw-mat-form');
    if (wmf) wmf.addEventListener('submit', handleWithdrawMaterial);

    // Tool Operations
    const btf = document.getElementById('borrow-tool-form');
    if (btf) btf.addEventListener('submit', handleBorrowTool);
    
    const retf = document.getElementById('return-tool-form');
    if (retf) retf.addEventListener('submit', handleReturnTool);
    
    const ttf = document.getElementById('transfer-tool-form');
    if (ttf) ttf.addEventListener('submit', handleTransferTool);
    
    const reptf = document.getElementById('repair-tool-form');
    if (reptf) reptf.addEventListener('submit', handleRepairTool);
}

// ========================
// VOICE SEARCH
// ========================
function startVoice(inputId, btnId) {
    if (!('webkitSpeechRecognition' in window)) {
        showToast('à¹€à¸šà¸£à¸²à¸§à¹Œà¹€à¸‹à¸­à¸£à¹Œà¸‚à¸­à¸‡à¸„à¸¸à¸“à¹„à¸¡à¹ˆà¸£à¸­à¸‡à¸£à¸±à¸šà¸£à¸°à¸šà¸šà¸ªà¸±à¹ˆà¸‡à¸‡à¸²à¸™à¸”à¹‰à¸§à¸¢à¹€à¸ªà¸µà¸¢à¸‡', 'error');
        return;
    }
    const recognition = new webkitSpeechRecognition();
    recognition.lang = 'th-TH';
    recognition.interimResults = false;
    
    const btn = document.getElementById(btnId);
    const originalColor = btn.style.color;
    btn.style.color = '#ef4444'; // Red to indicate listening
    showToast('à¸à¸³à¸¥à¸±à¸‡à¸Ÿà¸±à¸‡à¸„à¸³à¸ªà¸±à¹ˆà¸‡à¹€à¸ªà¸µà¸¢à¸‡...', 'info');
    
    recognition.onresult = function(event) {
        const text = event.results[0][0].transcript;
        const input = document.getElementById(inputId);
        input.value = text;
        showToast('à¸£à¸±à¸šà¸„à¸³à¸ªà¸±à¹ˆà¸‡: ' + text, 'success');
        input.dispatchEvent(new Event('input')); // trigger search if bound
        btn.style.color = originalColor;
    };
    
    recognition.onerror = function(event) {
        showToast('à¸‚à¹‰à¸­à¸œà¸´à¸”à¸žà¸¥à¸²à¸”à¹€à¸ªà¸µà¸¢à¸‡: ' + event.error, 'error');
        btn.style.color = originalColor;
    };
    
    recognition.onend = function() {
        btn.style.color = originalColor;
    };
    
    recognition.start();
}

// ========================
// SEARCH FILTERING
// ========================
function bindSearch() {
    filterList('mat-search', 'materials-table-body', 'tr');
    filterList('tool-search', 'tools-list-container', '.card');
    filterList('log-search', 'history-table-body', 'tr');
}

function filterList(inputId, containerId, itemSelector) {
    const input = document.getElementById(inputId);
    if (!input) return;
    input.addEventListener('input', function(e) {
        const term = e.target.value.toLowerCase().trim();
        const container = document.getElementById(containerId);
        if (!container) return;
        const items = container.querySelectorAll(itemSelector);
        items.forEach(item => {
            const text = item.textContent.toLowerCase();
            if (text.includes(term)) {
                item.style.display = '';
            } else {
                item.style.display = 'none';
            }
        });
    });
}

// ========================
// ALERTS
// ========================
function showCenterAlert(title, message) {
    const modal = document.getElementById('center-alert-modal');
    if (modal) {
        document.getElementById('center-alert-title').textContent = title || 'à¸ªà¸³à¹€à¸£à¹‡à¸ˆ';
        document.getElementById('center-alert-message').textContent = message || '';
        openModal('center-alert-modal');
        setTimeout(() => {
            closeModal('center-alert-modal');
        }, 3000);
    }
}

// ========================
// REPORTS
// ========================
function generateMonthlyReport() {
    const projSelect = document.getElementById('report-project-select');
    if(projSelect && projSelect.value) {
        document.getElementById('ui-report-meta').textContent = 'à¹‚à¸„à¸£à¸‡à¸à¸²à¸£: ' + projSelect.options[projSelect.selectedIndex].text;
        document.getElementById('print-report-meta').textContent = 'à¹‚à¸„à¸£à¸‡à¸à¸²à¸£: ' + projSelect.options[projSelect.selectedIndex].text;
    }
    
    const matTbody = document.getElementById('report-materials-tbody');
    const materials = AppDB.getMaterials();
    matTbody.innerHTML = '';
    let totalMatPrice = 0;
    materials.slice(0, 10).forEach((m, idx) => {
        let totalQty = Math.floor(Math.random() * 50) + 1; // Mock qty used
        let lineTotal = totalQty * (m.price_per_unit || 0);
        totalMatPrice += lineTotal;
        matTbody.innerHTML += `
            <tr>
                <td style="text-align:center;">${idx + 1}</td>
                <td>${m.name}</td>
                <td>${m.category}</td>
                <td style="text-align:center;">${totalQty} ${m.unit}</td>
                <td style="text-align:right;">${(m.price_per_unit||0).toLocaleString()}</td>
                <td style="text-align:right;">${lineTotal.toLocaleString()}</td>
            </tr>
        `;
    });
    
    const toolTbody = document.getElementById('report-tools-tbody');
    const tools = AppDB.getTools();
    toolTbody.innerHTML = '';
    tools.slice(0, 5).forEach((t, idx) => {
        toolTbody.innerHTML += `
            <tr>
                <td style="text-align:center;">${idx + 1}</td>
                <td>${t.name}</td>
                <td>à¸¢à¸·à¸¡à¹ƒà¸Šà¹‰à¸‡à¸²à¸™</td>
                <td>à¸ªà¸¡à¸Šà¸²à¸¢ à¹ƒà¸ˆà¸”à¸µ</td>
                <td>${new Date().toLocaleDateString('th-TH')}</td>
            </tr>
        `;
    });
    
    document.getElementById('report-summary-value').textContent = totalMatPrice.toLocaleString() + ' à¸šà¸²à¸—';
    document.getElementById('report-output-container').style.display = 'block';
}

// ========================
// USERS CRUD
// ========================
function renderUsers() {
    const tbody = document.getElementById('users-table-body');
    if (!tbody) return;
    tbody.innerHTML = '';
    const users = AppDB.getUsers();
    users.forEach(u => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <div style="font-weight:bold;">${u.name}</div>
                <div style="font-size:12px; color:var(--text-muted);">${u.username}</div>
            </td>
            <td>${getRoleName(u.role)}</td>
            <td>
                <span class="status-badge ${u.status === 'active' ? 'status-usable' : 'status-damaged'}">
                    ${u.status === 'active' ? 'à¹ƒà¸Šà¹‰à¸‡à¸²à¸™à¸›à¸à¸•à¸´' : 'à¸£à¸°à¸‡à¸±à¸šà¸à¸²à¸£à¹ƒà¸Šà¹‰à¸‡à¸²à¸™'}
                </span>
            </td>
            <td>
                <button class="btn btn-outline btn-sm" onclick="editUser('${u.id}')"><i class="fas fa-edit"></i> à¹à¸à¹‰à¹„à¸‚</button>
                <button class="btn btn-outline btn-sm" style="color:var(--danger);" onclick="deleteUser('${u.id}')"><i class="fas fa-trash"></i> à¸¥à¸š</button>
            </td>
        `;
        tbody.appendChild(tr);
    });
}

function openAddUserModal() {
    document.getElementById('user-form-el').reset();
    document.getElementById('user-form-id').value = '';
    document.getElementById('user-modal-title').textContent = 'à¹€à¸žà¸´à¹ˆà¸¡à¸žà¸™à¸±à¸à¸‡à¸²à¸™à¹ƒà¸«à¸¡à¹ˆ';
    openModal('user-modal');
}

function editUser(id) {
    const user = AppDB.getUsers().find(u => u.id === id);
    if (!user) return;
    document.getElementById('user-form-id').value = user.id;
    document.getElementById('user-name').value = user.name;
    document.getElementById('user-username').value = user.username;
    document.getElementById('user-password').value = user.password;
    document.getElementById('user-role').value = user.role;
    document.getElementById('user-status').value = user.status;
    document.getElementById('user-modal-title').textContent = 'à¹à¸à¹‰à¹„à¸‚à¸žà¸™à¸±à¸à¸‡à¸²à¸™';
    openModal('user-modal');
}

function deleteUser(id) {
    if (confirm('à¸„à¸¸à¸“à¹à¸™à¹ˆà¹ƒà¸ˆà¸«à¸£à¸·à¸­à¹„à¸¡à¹ˆà¸§à¹ˆà¸²à¸•à¹‰à¸­à¸‡à¸à¸²à¸£à¸¥à¸šà¸žà¸™à¸±à¸à¸‡à¸²à¸™à¸™à¸µà¹‰?')) {
        let users = AppDB.getUsers();
        users = users.filter(u => u.id !== id);
        saveToDB('Users', users);
        renderUsers();
        showToast('à¸¥à¸šà¸žà¸™à¸±à¸à¸‡à¸²à¸™à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', 'success');
    }
}

function handleUserForm(e) {
    e.preventDefault();
    const id = document.getElementById('user-form-id').value;
    const users = AppDB.getUsers();
    
    const newUser = {
        id: id || 'u' + Date.now(),
        name: document.getElementById('user-name').value,
        username: document.getElementById('user-username').value,
        password: document.getElementById('user-password').value,
        role: document.getElementById('user-role').value,
        status: document.getElementById('user-status').value
    };
    
    if (id) {
        const idx = users.findIndex(u => u.id === id);
        if (idx !== -1) users[idx] = newUser;
    } else {
        users.push(newUser);
    }
    
    saveToDB('Users', users);
    closeModal('user-modal');
    renderUsers();
    showToast('à¸šà¸±à¸™à¸—à¸¶à¸à¸‚à¹‰à¸­à¸¡à¸¹à¸¥à¸žà¸™à¸±à¸à¸‡à¸²à¸™à¸ªà¸³à¹€à¸£à¹‡à¸ˆ', 'success');
}

// ========================
// PROJECTS CRUD
