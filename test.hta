function saveToolsArray(tools) {
    let dbStr = localStorage.getItem('probuild_stock_db');
    if (dbStr) {
        let db = JSON.parse(dbStr);
        db.Tools = tools;
        localStorage.setItem('probuild_stock_db', JSON.stringify(db));
    }
}


function saveToDB(key, data) {
    let dbStr = localStorage.getItem('probuild_stock_db');
    if (dbStr) {
        let db = JSON.parse(dbStr);
        db[key] = data;
        localStorage.setItem('probuild_stock_db', JSON.stringify(db));
    }
}







